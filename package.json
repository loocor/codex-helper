{
  "name": "codex-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "bundle:runtime": "bun runtime/bundle.ts",
    "test:release": "bun test ./scripts/_test-release-workflow.test.js",
    "test:runtime": "bun test ./runtime",
    "build:bridge": "env RUSTC_WRAPPER= cargo build --manifest-path src-tauri/Cargo.toml --bin codex-helper-bridge",
    "launch": "bun run build:bridge && bun src/launch.ts",
    "build": "bun build src/launch.ts --target=bun --outdir=dist",
    "build:app": "./scripts/build-macos-app.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "typescript": "^5.8.0"
  }
}
